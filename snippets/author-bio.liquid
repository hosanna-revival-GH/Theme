{%- assign author = article.metafields.custom.author.value -%}

{%- if author != blank -%}
  {%- assign author_url = author.system.url -%}
  <div class="when-author-bio">

    {%- if author.photo != blank -%}
      <div class="when-author-bio__photo">
        {%- if author_url != blank -%}<a href="{{ author_url }}" aria-label="{{ author.name | escape }}">{%- endif -%}
          <img
            src="{{ author.photo | image_url: width: 200 }}"
            alt="{{ author.name }}"
            width="200"
            height="200"
          >
        {%- if author_url != blank -%}</a>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="when-author-bio__content">
      <h3 class="when-author-bio__name">
        {%- if author_url != blank -%}
          <a href="{{ author_url }}" style="color: inherit; text-decoration: none;">{{ author.name }}</a>
        {%- else -%}
          {{ author.name }}
        {%- endif -%}
      </h3>
      {%- if author.bio != blank -%}
        <p class="when-author-bio__bio">{{ author.bio }}</p>
      {%- endif -%}

      <div class="when-author-bio__social">
        {%- if author.instagram_url != blank -%}
          <a href="{{ author.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if author.facebook_url != blank -%}
          <a href="{{ author.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if author.pinterest_url != blank -%}
          <a href="{{ author.pinterest_url }}" aria-label="Pinterest" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        {%- endif -%}
        {%- if author.email != blank -%}
          <a href="mailto:{{ author.email }}" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
{%- endif -%}