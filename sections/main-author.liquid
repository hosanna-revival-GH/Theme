{%- comment -%}
  Author page: bio + every post by this author.
  Reuses the site's blog-card CSS (when-card / when-grid / when-author-bio from when-blog.css).
  Reads the current author via the global `metaobject`.
{%- endcomment -%}

{{ 'when-blog.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign author = metaobject
  assign blog_handle = section.settings.blog_handle | default: 'when-blog'
  assign target_blog = blogs[blog_handle]
  assign author_handle = author.system.handle
-%}

{%- if author != blank -%}

  {%- comment -%} ---------- BIO ---------- {%- endcomment -%}
  <div class="when-section">
    <div class="when-page-width">
      <div class="when-author-bio">
        {%- if author.photo != blank -%}
          <div class="when-author-bio__photo">
            <img src="{{ author.photo | image_url: width: 700 }}" alt="{{ author.name | escape }}" width="350" height="350" loading="eager">
          </div>
        {%- endif -%}
        <div class="when-author-bio__content">
          <h1 class="when-author-bio__name">{{ author.name }}</h1>
          {%- if author.bio != blank -%}
            <div class="when-author-bio__bio">{{ author.bio }}</div>
          {%- endif -%}
          <div class="when-author-bio__social">
            {%- if author.instagram_url != blank -%}
              <a href="{{ author.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
            {%- endif -%}
            {%- if author.facebook_url != blank -%}
              <a href="{{ author.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {%- endif -%}
            {%- if author.pinterest_url != blank -%}
              <a href="{{ author.pinterest_url }}" aria-label="Pinterest" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              </a>
            {%- endif -%}
            {%- if author.website_url != blank -%}
              <a href="{{ author.website_url }}" aria-label="Website" target="_blank" rel="noopener">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ---------- POSTS BY THIS AUTHOR ---------- {%- endcomment -%}
  <div class="when-section">
    <div class="when-page-width">
      <div class="when-section__head">
        <h2 class="when-section__title">{{ section.settings.heading }} {{ author.name }}</h2>
      </div>

      {%- assign found = 0 -%}
      {%- if target_blog != blank -%}
        {%- paginate target_blog.articles by 250 -%}
          <div class="when-grid">
            {%- for article in target_blog.articles -%}
              {%- assign art_author = article.metafields.custom.author.value -%}
              {%- unless art_author.system.handle == author_handle -%}{%- continue -%}{%- endunless -%}
              {%- assign found = found | plus: 1 -%}
              <article class="when-card">
                <a href="{{ article.url }}" class="when-card__link" tabindex="-1" aria-hidden="true">
                  {%- if article.image != blank -%}
                    <div class="when-card__image">
                      <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy" width="600" height="375">
                    </div>
                  {%- endif -%}
                </a>
                <div class="when-card__body">
                  <h3 class="when-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                  <div class="when-card__author">{{ author.name }}</div>
                  <div class="when-card__date">{{ article.published_at | date: '%B %-d, %Y' }}</div>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- endpaginate -%}
      {%- endif -%}

      {%- if found == 0 -%}<p>{{ section.settings.empty_text }}</p>{%- endif -%}
    </div>
  </div>

{%- endif -%}

{% schema %}
{
  "name": "Author page",
  "settings": [
    { "type": "text", "id": "blog_handle", "label": "Blog handle", "default": "when-blog", "info": "Which blog to pull this author's posts from." },
    { "type": "text", "id": "heading", "label": "Heading prefix", "default": "Articles by" },
    { "type": "text", "id": "empty_text", "label": "Empty state text", "default": "No articles yet." }
  ],
  "presets": [{ "name": "Author page" }]
}
{% endschema %}